{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": ["./apps/web/src/*"]
    }
  },
  "include": [
    "apps/web/next-env.d.ts",
    "apps/web/**/*.ts",
    "apps/web/**/*.tsx",
    "apps/web/.next/types/**/*.ts",
    "apps/web/.next/dev/types/**/*.ts",
    "apps/web/**/*.mts",
    "apps/web/.next/dev/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "MirrorBuddy-Memory",
    "e2e",
    "apps/web/e2e",
    "scripts",
    "feature",
    "feat"
  ]
}
